{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Run tests with coverage",
            "command": "./generate-coverage.sh",
            "args": [
                "build/dbg-sabre-tests"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none",
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "Docs / Build HTML",
            "command": "uv",
            "args": [
                "run",
                "make",
                "html"
            ],
            "options": {
                "cwd": "${workspaceFolder}/docs/",
                "env": {
                    "LC_ALL": "C"
                }
            },
            "group": "none",
            "problemMatcher": []
        }
    ]
}