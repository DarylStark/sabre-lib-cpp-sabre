{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20
    },
    "configurePresets": [
        {
            "name": "dbg-sabre-tests",
            "displayName": "Debug - Sabre, Tests",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/dbg-sabre-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SABRE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "dbg-sabre",
            "displayName": "Debug - Sabre",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/dbg-sabre",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SABRE_BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "rel-sabre-tests-tests",
            "displayName": "Release - Sabre, Tests",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/rel-sabre-tests",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SABRE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "rel-sabre",
            "displayName": "Release - Sabre",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/rel-sabre",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SABRE_BUILD_TESTS": "OFF"
            }
        }
    ]
}